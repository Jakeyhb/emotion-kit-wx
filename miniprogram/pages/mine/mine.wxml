<view class="page">
  <!-- 氛围背景 -->
  <view class="atmosphere">
    <view class="atmosphere-blob atmosphere-blob--1" />
    <view class="atmosphere-blob atmosphere-blob--2" />
  </view>

  <view class="profile">
    <view class="avatar-wrap">
      <view class="avatar-ring">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{ avatarUrl }}" class="avatar-img" src="{{ avatarUrl }}" mode="aspectFill" />
          <view wx:else class="avatar-fallback">
            <text class="avatar-fallback-char">记</text>
          </view>
        </button>
      </view>
      <text class="avatar-hint">轻点更换头像</text>
    </view>

    <view class="name-area">
      <text class="name-label">称呼</text>
      <input
        class="name-input"
        type="nickname"
        model:value="{{ nickName }}"
        placeholder="点此输入或同步微信昵称"
        placeholder-class="name-placeholder"
        maxlength="32"
        bindchange="onNicknameChange"
        bindblur="onNicknameBlur"
        bindconfirm="onNicknameConfirm"
        bindnicknamereview="onNicknameReview"
      />
    </view>

    <view class="slogan">
      <text class="slogan-main">情绪手记</text>
      <text class="slogan-dot">·</text>
      <text class="slogan-sub">安心记录每一刻</text>
    </view>
    <text class="privacy-line">头像与昵称仅保存在本机</text>
  </view>

  <view class="list-card">
    <van-cell-group inset>
      <van-cell title="我的背景" value="{{ premise ? '已填写' : '去填写' }}" is-link bind:click="openPremise" />
      <van-cell title="清空所有心情记录" is-link bind:click="clearAll" />
    </van-cell-group>
  </view>

  <view class="mask" wx:if="{{ showPremiseEdit }}" catchtouchmove="noop">
    <view class="modal" catchtouchmove="noop">
      <text class="modal-title">我的背景</text>
      <text class="modal-desc">写一点长期处境或性格特点，让解读更贴合你（可选）。</text>
      <textarea
        class="modal-input"
        placeholder="例如：最近工作节奏、与家人关系、身体状态…"
        value="{{ premiseDraft }}"
        maxlength="500"
        show-confirm-bar="{{ false }}"
        bindinput="onPremiseInput"
      />
      <view class="modal-btns">
        <button class="modal-btn secondary" bindtap="closePremise">取消</button>
        <button class="modal-btn primary" bindtap="savePremise">保存</button>
      </view>
    </view>
  </view>
</view>
