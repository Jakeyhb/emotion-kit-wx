/* 我的页：与全局 Apple 式中性风一致 */

.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 0 calc(80rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

/* 顶部柔光氛围（不写死大块纯色顶栏） */
.atmosphere {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 420rpx;
  pointer-events: none;
  z-index: 0;
}

.atmosphere-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(2rpx);
}

.atmosphere-blob--1 {
  width: 520rpx;
  height: 360rpx;
  left: -120rpx;
  top: -120rpx;
  background: radial-gradient(ellipse at 40% 40%, rgba(130, 175, 165, 0.28) 0%, rgba(236, 244, 241, 0.55) 55%, transparent 72%);
}

.atmosphere-blob--2 {
  width: 400rpx;
  height: 320rpx;
  right: -100rpx;
  top: 40rpx;
  background: radial-gradient(ellipse at 60% 50%, rgba(252, 254, 253, 0.95) 0%, rgba(160, 190, 182, 0.18) 45%, transparent 65%);
}

/* 个人区 */
.profile {
  position: relative;
  z-index: 1;
  margin: 0 36rpx;
  padding: 48rpx 40rpx 40rpx;
  background: var(--ek-surface);
  border-radius: var(--ek-radius-block);
  border: 1rpx solid var(--ek-border);
  box-shadow: var(--ek-shadow-card-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 外环固定正圆，避免 button 被系统拉成椭圆 */
.avatar-ring {
  width: 176rpx;
  height: 176rpx;
  padding: 6rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffffff 0%, #eef3f1 55%, #dce6e2 100%);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.avatar-btn {
  display: block;
  width: 164rpx !important;
  height: 164rpx !important;
  min-height: 164rpx !important;
  padding: 0 !important;
  margin: 0;
  line-height: 0 !important;
  border-radius: 50% !important;
  overflow: hidden;
  background: var(--ek-bg) !important;
  border: none !important;
  box-sizing: border-box;
}

.avatar-btn::after {
  border: none !important;
}

.avatar-img {
  display: block;
  width: 164rpx;
  height: 164rpx;
  border-radius: 50%;
}

.avatar-fallback {
  width: 164rpx;
  height: 164rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #3d7a6e 0%, #265a50 100%);
}

.avatar-fallback-char {
  font-size: 56rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 0.02em;
}

.avatar-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--ek-text-hint);
  letter-spacing: 0.06em;
}

/* 昵称：底线式，去掉大灰药丸 */
.name-area {
  width: 100%;
  margin-top: 40rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.name-label {
  display: block;
  font-size: 22rpx;
  color: var(--ek-text-secondary);
  letter-spacing: 0.2em;
  margin-bottom: 12rpx;
  text-align: center;
}

.name-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--ek-text);
  padding: 0 24rpx;
  box-sizing: border-box;
  background: transparent;
  border-bottom: 2rpx solid var(--ek-border-strong);
  border-radius: 0;
}

.name-placeholder {
  color: var(--ek-text-hint);
  font-size: 28rpx;
  font-weight: 400;
}

.slogan {
  margin-top: 36rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.slogan-main {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ek-primary);
  letter-spacing: 0.12em;
}

.slogan-dot {
  font-size: 24rpx;
  color: var(--ek-secondary);
}

.slogan-sub {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  letter-spacing: 0.08em;
}

.privacy-line {
  margin-top: 20rpx;
  font-size: 20rpx;
  color: var(--ek-text-hint);
}

/* 云状态：一行胶囊，不再堆长文 */
.sync-pill {
  position: relative;
  z-index: 1;
  margin: 28rpx 36rpx 0;
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: var(--ek-surface);
  border: 1rpx solid var(--ek-border);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: var(--ek-shadow-card-sm);
}

.sync-pill--warn {
  border-color: rgba(200, 140, 90, 0.35);
  background: rgba(255, 248, 240, 0.95);
}

.sync-pill-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--ek-primary);
  box-shadow: 0 0 0 6rpx var(--ek-primary-soft);
  flex-shrink: 0;
}

.sync-pill-text {
  font-size: 24rpx;
  color: var(--ek-text-secondary);
  line-height: 1.45;
  text-align: center;
}

.list-card {
  position: relative;
  z-index: 1;
  margin: 28rpx 28rpx 0;
  border-radius: var(--ek-radius-inner);
  overflow: hidden;
  box-shadow: var(--ek-shadow-card-sm);
  border: 1rpx solid var(--ek-border);
}

/* 与 van-cell 行高一致，用 bindtap 直连页面方法 */
.mine-ai-test-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  min-height: 88rpx;
  box-sizing: border-box;
  background: var(--ek-surface);
  border-bottom: 1rpx solid var(--ek-border);
}

.mine-ai-test-row--hover {
  background: var(--ek-bg-tint);
}

.mine-ai-test-row-body {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.mine-ai-test-title {
  display: block;
  font-size: 30rpx;
  color: var(--ek-text);
  line-height: 1.4;
}

.mine-ai-test-label {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--ek-text-secondary);
  line-height: 1.45;
}

.mine-ai-test-arrow {
  flex-shrink: 0;
  font-size: 36rpx;
  color: var(--ek-text-hint);
  font-weight: 300;
}

.footer-hint {
  position: relative;
  z-index: 1;
  margin: 32rpx 48rpx 0;
  font-size: 20rpx;
  color: var(--ek-text-hint);
  line-height: 1.5;
  text-align: center;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal {
  width: 100%;
  max-width: 620rpx;
  background: var(--ek-surface);
  border-radius: var(--ek-radius-block);
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  box-shadow: var(--ek-shadow-card);
  border: 1rpx solid var(--ek-border);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--ek-text);
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  line-height: 1.55;
  display: block;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid var(--ek-border-input);
  border-radius: var(--ek-radius-inner);
  box-sizing: border-box;
  margin-bottom: 28rpx;
  background: var(--ek-bg);
  color: var(--ek-text);
}

.modal-btns {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.modal-btn {
  font-size: 28rpx;
  margin: 0;
  min-width: 160rpx;
}

.modal-btn.primary {
  background: var(--ek-primary);
  color: #fff;
  font-weight: 600;
  border-radius: var(--ek-radius-pill);
}

.modal-btn.secondary {
  background: transparent;
  color: var(--ek-text-secondary);
  border-radius: var(--ek-radius-pill);
}
