/* 情绪页：Apple 式留白与层级 */
.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 40rpx 140rpx;
}

/* 顶部说明 */
.intro {
  margin-bottom: 48rpx;
}
.intro-text {
  font-size: 30rpx;
  color: var(--ek-text-secondary);
  line-height: 1.6;
}

/* 我的背景：首页小按钮 */
.intro {
  position: relative;
  padding-right: 140rpx;
}
.premise-btn {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 26rpx;
  color: var(--ek-primary);
  padding: 8rpx 16rpx;
}
/* 我的背景：弹窗（首次必填 / 修改） */
.premise-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}
.premise-modal-box {
  width: 100%;
  max-width: 600rpx;
  background: var(--ek-surface);
  border-radius: var(--ek-radius-block);
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  box-shadow: var(--ek-shadow-card);
  border: 1rpx solid var(--ek-border);
}
.premise-modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--ek-text);
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx;
}
.premise-modal-desc {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  display: block;
  margin-bottom: 24rpx;
}
.premise-modal-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--ek-text);
  background: var(--ek-bg);
  border-radius: var(--ek-radius-inner);
  border: 1rpx solid var(--ek-border-input);
  box-sizing: border-box;
  margin-bottom: 28rpx;
}
.premise-modal-btns {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}
.premise-btn-secondary {
  font-size: 28rpx;
  color: var(--ek-text-secondary);
  background: transparent;
  padding: 16rpx 28rpx;
  border: none;
}
.premise-btn-secondary::after {
  border: none;
}
.premise-btn-primary {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: var(--ek-primary);
  padding: 16rpx 32rpx;
  border-radius: var(--ek-radius-pill);
  border: none;
}
.premise-btn-primary::after {
  border: none;
}

/* 日历：默认周视图，可切换月视图 */
.calendar-section {
  padding: 24rpx 28rpx 28rpx;
}
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}
.calendar-view-toggle {
  font-size: 26rpx;
  color: var(--ek-text-hint);
}
.toggle-item.active {
  color: var(--ek-primary);
  font-weight: 500;
}
.toggle-divider {
  margin: 0 6rpx;
  color: #c0c0c0;
}
.calendar-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ek-text);
  flex: 1;
  text-align: center;
  letter-spacing: -0.3rpx;
}
.calendar-nav {
  display: flex;
  gap: 24rpx;
}
.calendar-nav-btn {
  font-size: 36rpx;
  color: var(--ek-primary);
  padding: 8rpx 16rpx;
  line-height: 1;
}
.calendar-weekdays {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}
.weekday {
  font-size: 22rpx;
  color: var(--ek-text-hint);
  width: 14.28%;
  text-align: center;
}
.calendar-grid {
  margin-bottom: 20rpx;
}
.calendar-grid.week-grid {
  display: flex;
  justify-content: space-around;
  padding: 0 4rpx;
}
.calendar-cell {
  width: 14.28%;
  min-height: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 4rpx;
  border-radius: 16rpx;
  background: transparent;
  transition: background 0.2s;
}
.calendar-cell.today {
  background: var(--ek-cal-today);
  color: var(--ek-text);
}
.calendar-cell.has-record .cell-day {
  font-weight: 500;
  color: var(--ek-text);
}
.calendar-cell.selected {
  background: var(--ek-cal-selected);
}
.calendar-cell.other-month .cell-day {
  color: #c0c0c0;
}
.cell-day {
  font-size: 28rpx;
  color: var(--ek-text-secondary);
  display: block;
}
.cell-mood-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}
.calendar-row {
  display: flex;
  justify-content: space-around;
  padding: 4rpx 0;
}
.month-grid .calendar-cell {
  min-height: 56rpx;
  padding: 8rpx 2rpx;
}
.month-grid .cell-mood-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 6rpx;
}
.selected-day-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.selected-day-section .section-title {
  margin-bottom: 16rpx;
}
.selected-day-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.calendar-hint {
  font-size: 24rpx;
  color: var(--ek-text-hint);
  margin-top: 16rpx;
  text-align: center;
}

/* 区块：与打卡页一致的模块背景，与网格纸区分 */
.section {
  background: var(--ek-surface);
  border-radius: var(--ek-radius-block);
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--ek-shadow-card-sm);
  border: 1rpx solid var(--ek-border);
}
.section-hint {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  display: block;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ek-text);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: -0.3rpx;
}
.section-desc {
  font-size: 24rpx;
  color: var(--ek-text-secondary);
  line-height: 1.45;
  display: block;
  margin-bottom: 24rpx;
}

/* 三问记录：纯 WXSS 优化，不依赖 UI 库 */
.q-section {
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--ek-shadow-card-sm);
  border: 1rpx solid var(--ek-border);
}
.q-section:last-of-type {
  margin-bottom: 0;
}

.q-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ek-text);
  letter-spacing: 0.5rpx;
  margin-bottom: 10rpx;
  line-height: 1.4;
}
.q-hint {
  display: block;
  font-size: 24rpx;
  color: var(--ek-text-hint);
  line-height: 1.45;
  margin-bottom: 24rpx;
}

/* 问题一：情绪芯片 */
.emotion-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}
.emotion-chip {
  padding: 18rpx 28rpx;
  border-radius: var(--ek-radius-pill);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--ek-text-secondary);
  background: var(--ek-bg-tint);
  border: 2rpx solid var(--ek-border);
  transition: transform var(--ek-transition), box-shadow var(--ek-transition);
}
.emotion-chip:active {
  transform: scale(0.97);
}
.emotion-chip.selected {
  background: var(--emotion-color, #6b8f84);
  border-color: var(--emotion-color, #6b8f84);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

/* 问题二：左情绪、中间五段线（颜色表强度）、右文案，与详情页一致；选中强调、其余弱化 */
.degree-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.degree-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--ek-border);
}
.degree-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.degree-name {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 600;
  min-width: 88rpx;
  letter-spacing: 0.5rpx;
}
.degree-line-wrap {
  flex: 1;
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  min-height: 32rpx;
}
.degree-segment {
  flex: 1;
  height: 6rpx;
  border-radius: 3rpx;
  background: rgba(0, 0, 0, 0.06);
  transition: height 0.2s ease, background 0.2s ease;
}
.degree-segment:active {
  opacity: 0.9;
}
.degree-segment.active {
  height: 12rpx;
  border-radius: 4rpx;
}
.degree-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--ek-text-secondary);
  font-weight: 500;
  min-width: 64rpx;
  text-align: right;
}

/* 问题三：情境/联想输入 */
.q3-input {
  width: 100%;
  min-height: 140rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--ek-text);
  line-height: 1.55;
  background: var(--ek-bg-tint);
  border-radius: 20rpx;
  border: 2rpx solid var(--ek-border-input);
  box-sizing: border-box;
  transition: border-color var(--ek-transition), background var(--ek-transition);
}
.q3-input::placeholder {
  color: var(--ek-text-hint);
}

/* 主按钮 */
.action-wrap {
  margin-top: 32rpx;
  margin-bottom: 48rpx;
}
.action-hint {
  display: block;
  font-size: 24rpx;
  color: var(--ek-text-hint);
  text-align: center;
  margin-bottom: 16rpx;
}
.btn-save {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: var(--ek-primary);
  border: none;
  border-radius: var(--ek-radius-pill);
  box-shadow: var(--ek-shadow-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  transition: transform var(--ek-transition), opacity var(--ek-transition);
}
.btn-save:active {
  transform: scale(0.98);
  opacity: 0.92;
}
.btn-save::after {
  border: none;
}
.today-done {
  margin-top: 24rpx;
  text-align: center;
}
.today-done-text {
  font-size: 28rpx;
  color: var(--ek-text-secondary);
  display: block;
}
.today-done-sub {
  font-size: 26rpx;
  color: var(--ek-link);
  margin-top: 8rpx;
  display: inline-block;
}

/* 历史记录 */
.recent-section {
  padding: 32rpx 32rpx 36rpx;
}
.recent-section-header {
  margin-bottom: 24rpx;
}
.recent-section .section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--ek-text);
  letter-spacing: -0.5rpx;
  margin-bottom: 8rpx;
}
.recent-section .section-desc {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  line-height: 1.5;
}
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 卡片：白底、细线、轻阴影（Apple 产品页模块感） */
.recent-card {
  position: relative;
  padding: 28rpx 28rpx 28rpx 36rpx;
  margin-left: 0;
  border-radius: var(--ek-radius-inner);
  overflow: hidden;
  background: var(--ek-surface);
  border: 1rpx solid var(--ek-border);
  box-shadow: var(--ek-shadow-card-sm);
  transition: transform var(--ek-transition), box-shadow var(--ek-transition);
  animation: glassCardIn 0.45s cubic-bezier(0.25, 0.1, 0.25, 1) both;
}
.recent-list .recent-card:nth-child(1) { animation-delay: 0.02s; }
.recent-list .recent-card:nth-child(2) { animation-delay: 0.06s; }
.recent-list .recent-card:nth-child(3) { animation-delay: 0.1s; }
.recent-list .recent-card:nth-child(4) { animation-delay: 0.14s; }
.recent-list .recent-card:nth-child(5) { animation-delay: 0.18s; }
.recent-list .recent-card:nth-child(n+6) { animation-delay: 0.22s; }
.recent-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, var(--mood-color, #7a9a8e) 0%, transparent 100%);
  opacity: 0.9;
}
.recent-card:active {
  transform: scale(0.99);
  box-shadow: var(--ek-shadow-card-sm);
}

.recent-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.recent-card-time {
  font-size: 24rpx;
  color: var(--ek-text-hint);
  letter-spacing: 0.2rpx;
  font-weight: 500;
}
.recent-card-mood {
  padding: 6rpx 14rpx;
  border-radius: var(--ek-radius-pill);
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
  line-height: 1.3;
  box-shadow: none;
}

.recent-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}
.recent-card-tag {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: var(--mood-color, #6e6e73);
  background: var(--ek-bg);
  border: 1rpx solid var(--ek-border);
  line-height: 1.4;
}

.recent-card-do {
  padding-top: 12rpx;
  border-top: 1rpx solid var(--ek-border);
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  min-height: 0;
}
.recent-card-do-label {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--ek-text-hint);
  line-height: 1.5;
}
.recent-card-do-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@keyframes glassCardIn {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.selected-day-empty {
  font-size: 28rpx;
  color: var(--ek-text-hint);
  text-align: center;
  padding: 32rpx 0;
  display: block;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 48rpx 24rpx;
}
.empty-text {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
}

/* 自定义提示：柔和俏皮，支持多种类型 */
.custom-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  opacity: 0;
  z-index: 9999;
  pointer-events: none;
  transition: all 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
}

.custom-toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.toast-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 48rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20rpx);
  border-radius: var(--ek-radius-block);
  box-shadow: var(--ek-shadow-card), 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  min-width: 200rpx;
  max-width: 500rpx;
}

.toast-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
  animation: toastBounce 0.5s cubic-bezier(0.34, 1.2, 0.64, 1);
}

.toast-badge--success {
  background: var(--ek-success);
}

.toast-badge--error {
  background: var(--ek-danger);
}

.toast-badge--info {
  background: var(--ek-text-hint);
}

.toast-text {
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  text-align: center;
  word-break: break-all;
  line-height: 1.4;
}

/* 成功类型 */
.custom-toast.toast-success .toast-text {
  color: var(--ek-text);
}

/* 错误类型 */
.custom-toast.toast-error .toast-text {
  color: var(--ek-text);
}

/* 信息类型 */
.custom-toast.toast-info .toast-text {
  color: var(--ek-text-secondary);
}

@keyframes toastBounce {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.15);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 回到顶部：可爱悬浮，滚动后显示 */
.back-top {
  position: fixed;
  right: 32rpx;
  bottom: 50rpx;
  z-index: 100;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--ek-surface);
  border: 1rpx solid var(--ek-border-strong);
  box-shadow: var(--ek-shadow-card-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
  animation: backTopIn 0.3s ease;
}
.back-top:active {
  transform: scale(0.94);
  opacity: 0.9;
}
.back-top-icon {
  font-size: 32rpx;
  color: var(--ek-text);
  line-height: 1;
  font-weight: 600;
  margin-top: -4rpx;
}
.back-top-text {
  font-size: 20rpx;
  color: var(--ek-text-secondary);
  letter-spacing: 0.5rpx;
  margin-top: 2rpx;
}
@keyframes backTopIn {
  from {
    opacity: 0;
    transform: scale(0.6) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}
