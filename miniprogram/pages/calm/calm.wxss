/* 调节页：层次、阶段轨、呼吸环与克制动效 */

.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 36rpx calc(120rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

.page--ready .card--intro {
  opacity: 1;
  transform: translateY(0);
}

.page--ready .phase-track {
  opacity: 1;
  transform: translateY(0);
}

.page--ready .ring-wrap {
  opacity: 1;
  transform: translateY(0) scale(1);
}

/* 背景氛围 */
.atmosphere {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.atmosphere-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(1rpx);
}

.atmosphere-blob--1 {
  width: 520rpx;
  height: 420rpx;
  left: -160rpx;
  top: -100rpx;
  background: radial-gradient(ellipse at 35% 40%, rgba(45, 106, 95, 0.14) 0%, rgba(233, 240, 237, 0.5) 55%, transparent 70%);
  animation: blobDriftA 18s ease-in-out infinite alternate;
}

.atmosphere-blob--2 {
  width: 440rpx;
  height: 380rpx;
  right: -120rpx;
  top: 28%;
  background: radial-gradient(ellipse at 60% 50%, rgba(255, 255, 255, 0.85) 0%, rgba(45, 106, 95, 0.06) 48%, transparent 68%);
  animation: blobDriftB 22s ease-in-out infinite alternate;
}

@keyframes blobDriftA {
  from {
    transform: translate(0, 0) scale(1);
  }
  to {
    transform: translate(24rpx, 16rpx) scale(1.04);
  }
}

@keyframes blobDriftB {
  from {
    transform: translate(0, 0);
  }
  to {
    transform: translate(-20rpx, 32rpx);
  }
}

/* 介绍卡片 */
.card {
  position: relative;
  z-index: 1;
  background: var(--ek-surface);
  border-radius: var(--ek-radius-block);
  padding: 36rpx 40rpx 32rpx;
  margin-bottom: 36rpx;
  box-shadow: var(--ek-shadow-card-sm), 0 0 0 1rpx rgba(45, 106, 95, 0.04);
  border: 1rpx solid var(--ek-border);
}

.card--intro {
  opacity: 0;
  transform: translateY(24rpx);
  transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1), transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
}

.intro-kicker {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--ek-primary);
  opacity: 0.85;
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ek-text);
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.desc {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  line-height: 1.65;
  display: block;
}

/* 四阶段时间轴 */
.phase-track {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 0 8rpx;
  margin-bottom: 40rpx;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 0.5s 0.08s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s 0.08s cubic-bezier(0.22, 1, 0.36, 1);
}

.phase-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0 4rpx;
  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.35s ease;
}

.phase-step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(26, 38, 36, 0.12);
  margin-bottom: 12rpx;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.35s ease, box-shadow 0.35s ease;
}

.phase-step-label {
  font-size: 22rpx;
  color: var(--ek-text-hint);
  font-weight: 500;
  transition: color 0.35s ease, font-weight 0.35s ease;
}

.phase-step-sec {
  font-size: 20rpx;
  color: var(--ek-text-hint);
  margin-top: 4rpx;
  opacity: 0.85;
}

.phase-step--past .phase-step-dot {
  background: rgba(45, 106, 95, 0.35);
  transform: scale(0.92);
}

.phase-step--active .phase-step-dot {
  background: var(--ek-primary);
  transform: scale(1.35);
  box-shadow: 0 0 0 8rpx var(--ek-primary-soft), 0 4rpx 16rpx rgba(45, 106, 95, 0.35);
}

.phase-step--active .phase-step-label {
  color: var(--ek-primary);
  font-weight: 700;
}

.phase-step--active .phase-step-sec {
  color: var(--ek-text-secondary);
}

/* 呼吸环容器 */
.ring-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  margin: 8rpx 0 48rpx;
  opacity: 0;
  transform: translateY(20rpx) scale(0.96);
  transition: opacity 0.6s 0.12s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s 0.12s cubic-bezier(0.22, 1, 0.36, 1);
}

.ring-shell {
  position: relative;
  width: 460rpx;
  height: 460rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-orbit {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 448rpx;
  height: 448rpx;
  margin-left: -224rpx;
  margin-top: -224rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  border-top-color: rgba(45, 106, 95, 0.45);
  border-right-color: rgba(45, 106, 95, 0.12);
  opacity: 0;
  transform: rotate(0deg);
  animation: orbitSweep 16s linear infinite;
  animation-play-state: paused;
  pointer-events: none;
}

.ring-shell--running .ring-orbit {
  opacity: 1;
  animation-play-state: running;
}

@keyframes orbitSweep {
  to {
    transform: rotate(360deg);
  }
}

.ring-halo {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.ring-halo--1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(45, 106, 95, 0.12) 0%, transparent 68%);
}

.ring-halo--2 {
  width: 440rpx;
  height: 440rpx;
  background: radial-gradient(circle, rgba(45, 106, 95, 0.06) 0%, transparent 72%);
}

.ring-shell--running .ring-halo {
  opacity: 1;
}

.ring-shell--running .ring-halo--1 {
  animation: haloPulse 4s ease-in-out infinite;
}

.ring-shell--running .ring-halo--2 {
  animation: haloPulse 4s ease-in-out infinite 0.5s;
}

@keyframes haloPulse {
  0%,
  100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.55;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.06);
    opacity: 0.9;
  }
}

.ring {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: linear-gradient(165deg, rgba(255, 255, 255, 0.98) 0%, var(--ek-bg-tint) 52%, rgba(233, 240, 237, 0.96) 100%);
  border: 8rpx solid rgba(26, 46, 42, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 32rpx;
  box-shadow: var(--ek-shadow-card-sm), inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
  transition: border-color 0.55s cubic-bezier(0.22, 1, 0.36, 1), transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.55s ease, filter 0.55s ease;
}

.ring-inner-shine {
  position: absolute;
  inset: 12%;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 28%, rgba(255, 255, 255, 0.55) 0%, transparent 52%);
  pointer-events: none;
  opacity: 0.7;
}

.ring--active {
  border-color: rgba(45, 106, 95, 0.45);
  transform: scale(1.02);
  box-shadow: var(--ek-shadow-primary-soft), inset 0 1rpx 0 rgba(255, 255, 255, 0.65);
  animation: ringBreath 4s ease-in-out infinite;
}

.ring--in.ring--active {
  filter: saturate(1.05) hue-rotate(-4deg);
}

.ring--out.ring--active {
  filter: saturate(1.08) hue-rotate(6deg);
}

.ring--hold1.ring--active,
.ring--hold2.ring--active {
  filter: saturate(0.98);
  border-color: rgba(45, 106, 95, 0.32);
}

@keyframes ringBreath {
  0%,
  100% {
    transform: scale(1.02);
  }
  50% {
    transform: scale(1.045);
  }
}

.ring-label {
  position: relative;
  z-index: 1;
  font-size: 30rpx;
  color: var(--ek-primary);
  margin-bottom: 10rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.ring-num {
  position: relative;
  z-index: 1;
  font-size: 108rpx;
  font-weight: 700;
  color: var(--ek-text);
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: -2rpx;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease;
}

.ring--active .ring-num {
  animation: numTick 1s ease-in-out infinite;
}

@keyframes numTick {
  0% {
    transform: scale(1);
  }
  8% {
    transform: scale(1.04);
  }
  18% {
    transform: scale(1);
  }
  100% {
    transform: scale(1);
  }
}

.ring-hint {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  font-size: 24rpx;
  color: var(--ek-text-secondary);
  text-align: center;
  line-height: 1.55;
  max-width: 300rpx;
  transition: opacity 0.35s ease;
}

/* 统计 */
.stats {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.stats-pill {
  display: inline-flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--ek-primary-soft) 0%, rgba(45, 106, 95, 0.05) 100%);
  border: 1rpx solid rgba(45, 106, 95, 0.12);
  animation: statsPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes statsPop {
  from {
    opacity: 0;
    transform: scale(0.88) translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.stats-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ek-primary);
  line-height: 1;
}

.stats-text {
  font-size: 26rpx;
  color: var(--ek-text-secondary);
  font-weight: 500;
}

/* 按钮 */
.actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 24rpx;
  justify-content: center;
  flex-wrap: wrap;
}

.btn {
  min-width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--ek-radius-pill);
  font-size: 28rpx;
  margin: 0;
  padding: 0 40rpx;
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s ease, opacity 0.2s ease;
}

.btn::after {
  border: none;
}

.btn-label {
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(165deg, #358a7c 0%, var(--ek-primary) 48%, #245a52 100%);
  color: #fff;
  box-shadow: var(--ek-shadow-primary), 0 1rpx 0 rgba(255, 255, 255, 0.2) inset;
}

.btn-primary--pause {
  background: linear-gradient(165deg, #5a8a82 0%, #3d7268 100%);
  box-shadow: 0 6rpx 24rpx rgba(45, 106, 95, 0.2);
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.96;
}

.btn-ghost {
  background: var(--ek-surface);
  color: var(--ek-text);
  border: 2rpx solid var(--ek-border-strong);
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(20, 40, 36, 0.04);
}

.btn-ghost:active {
  transform: scale(0.97);
}
