PORT=8787

# DashScope config
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_API_HOST=dashscope.aliyuncs.com
DASHSCOPE_MODEL=qwen3-max

# Optional service auth token (recommended)
SERVICE_TOKEN=replace_with_strong_random_token

# Optional: separate token for /admin log UI only (defaults to SERVICE_TOKEN)
# LOG_ADMIN_TOKEN=

# Log file rotation / read limits (optional)
# LOG_MAX_FILE_BYTES=2097152
# LOG_READ_MAX_LINES=500

# MySQL（配置后日志会落库，React 管理页 /log-admin/ 使用 GET /api/logs）
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=emotion_kit_ai
# MYSQL_POOL_MAX=10

# 若前端单独域名开发，可设 CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=

# 管理后台：首次 admin_users 为空时创建 admin/admin（创建后请去掉 BOOTSTRAP）
# ADMIN_BOOTSTRAP=1
# 已有 admin 但密码忘了：与上一行同时设 1，启动一次把 admin 密码重置为 admin，然后立刻删掉两行
# ADMIN_BOOTSTRAP_RESET_ADMIN=1

# JWT 签名密钥（建议单独设置长随机串；不设置则用 SERVICE_TOKEN 派生）
# ADMIN_JWT_SECRET=
